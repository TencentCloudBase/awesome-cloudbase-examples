{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "envId": "your-env-id",
  "functions": [
    {
      "name": "offiaccount-common",
      "type": "HTTP",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 15,
      "memorySize": 128,
      "installDependency": true,
      "environmentVariables": {
        "OA_APPID": "YOUR_APPID",
        "OA_APPSECRET": "YOUR_APPSECRET"
      },
      "ignore": [
        "node_modules",
        ".git",
        ".env"
      ]
    }
  ]
}
