.container { padding: 30rpx; }
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: bold; display: block; }
.subtitle { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; }
.section { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; display: block; }
.form-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #eee; }
.label { width: 180rpx; font-size: 28rpx; color: #333; }
.input { flex: 1; font-size: 28rpx; padding: 10rpx; }
.btn { margin-top: 20rpx; border-radius: 12rpx; font-size: 30rpx; }
.btn-primary { background: #07c160; color: #fff; }
.btn-blue { background: #1989fa; color: #fff; }
.btn-red { background: #ee0a24; color: #fff; }
.btn-refund { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: #fff; font-weight: bold; }
.btn-refund:disabled { background: #ffcdd2; }
.result-box { background: #f8f8f8; border-radius: 8rpx; padding: 20rpx; max-height: 500rpx; width: auto; }
.result-text { font-size: 24rpx; color: #333; font-family: monospace; word-break: break-all; }
.order-info { display: flex; align-items: center; padding: 12rpx 0; }
.order-label { font-size: 28rpx; color: #666; flex-shrink: 0; width: 120rpx; }
.order-no { font-size: 26rpx; color: #1989fa; font-family: monospace; flex: 1; word-break: break-all; }
.refund-no { color: #f5576c; font-weight: bold; }
.openid-text { font-size: 24rpx; color: #1989fa; font-family: monospace; word-break: break-all; }
.btn-transfer { background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); color: #fff; font-weight: bold; }
.btn-transfer:disabled { background: #ffe0b2; }
.tip { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

/* Tab 栏 */
.tab-bar { display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 24rpx; overflow: hidden; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; position: relative; transition: all 0.2s; }
.tab-item.tab-active { color: #07c160; font-weight: bold; }
.tab-item.tab-active::after { content: ''; position: absolute; bottom: 0; left: 25%; width: 50%; height: 6rpx; background: #07c160; border-radius: 3rpx; }
