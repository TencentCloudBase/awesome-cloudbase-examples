# ============================================================================
# CloudBase 函数测试脚本环境变量样板
# Environment variables for the CloudBase function test scripts
# ----------------------------------------------------------------------------
# 用法 / Usage:
#   cp .env.example .env
#   # 然后编辑 .env，按需修改下面的取值
#   # then edit .env and fill in the values you need
#
# 注意 / Note:
#   - 实际的 .env 文件已被 .gitignore 忽略，不会被提交。
#   - The real .env file is ignored by .gitignore and will NOT be committed.
# ============================================================================

# CloudBase 环境 ID（必填）/ CloudBase environment ID (required for test-deploy.sh)
# 在 https://console.cloud.tencent.com/tcb 控制台可查看。
# Find it at https://console.cloud.tencent.com/tcb
ENV_ID=

# 函数名前缀（可选）/ Optional function name prefix.
# 设置后所有部署会以 "<前缀><函数名>" 形式上线，避免覆盖正式环境。
# 等价于命令行 --prefix。
# When set, deploys functions as "<prefix><name>" so production functions
# are not overwritten. Equivalent to the --prefix CLI flag.
# 例 / e.g.: TEST_NAME_PREFIX=test-
TEST_NAME_PREFIX=

# ---- 可选：通过 API 密钥免交互登录 ----------------------------------------
# Optional: non-interactive tcb login via secret key
# 若已通过 `tcb login` 完成交互登录则无需配置；CI 场景建议使用密钥登录。
# Not required when you already ran `tcb login` interactively. Recommended in CI.
# 控制台获取：https://console.cloud.tencent.com/cam/capi
# Get the keys at https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=

# ---- 可选：调试与运行控制 -------------------------------------------------
# Optional: debug & run control
# DEBUG=1 时部分脚本会保留临时文件并 set -x。
# When DEBUG=1, some scripts keep temp files and enable bash trace.
DEBUG=

# Tier 1 本地启动等待端口就绪的超时（秒）/ Local port readiness timeout (seconds)
LOCAL_PORT_TIMEOUT=15

# Tier 2 HTTP 调用单次请求超时（秒）/ HTTP request timeout for invoke (seconds)
HTTP_INVOKE_TIMEOUT=20

# Tier 2 HTTP 函数新建网关路由后的等待时长（秒），用于让 gateway 路由传播
# Wait time (seconds) after newly creating an HTTP service path, before invoking.
# Only applies when `tcb service create` actually creates a new path (not reuse).
HTTP_SERVICE_WAIT_SEC=15

# ---- 模板 CMS 同步（cloudfunctions/templates）---------------------------
# Template CMS sync (used by cloudfunctions/templates/scripts/*.mjs)
# 模板数据所在的云开发环境 ID（与上面的 ENV_ID 可不同）
# CloudBase env ID hosting the template data model (can differ from ENV_ID above)
TEMPLATE_ENV_ID=

# 数据模型唯一标识 / Data model identifier
# CloudBase 数据模型自带「体验数据」和「正式数据」双环境，push.mjs 用 --test 切换
# （无需额外创建测试模型）
TEMPLATE_MODEL_ID=tcb_template_list

# CloudBase 长期 API Key（管理员权限，仅可用于服务端）
# CloudBase long-lived API Key (admin privilege, server-side only).
# 控制台：https://tcb.cloud.tencent.com/dev#/env/apikey
# Console: https://tcb.cloud.tencent.com/dev#/env/apikey
CLOUDBASE_APIKEY=
