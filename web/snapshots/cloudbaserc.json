{
  "envId": "{{tcb.envId}}",
  "version": "2.0",
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "app": {
    "outputDir": "dest",
    "deployPath": "/snapshot"
  },
  "framework": {
    "name": "node-starter",
    "plugins": {
      "function": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functionRootPath": "./functions",
          "functions": [
            {
              "name": "snapshots",
              "timeout": 30,
              "envVariables": {},
              "runtime": "Nodejs10.15",
              "memory": 512,
              "handler": "index.main",
              "installDependency": false,
              "ignore": ["node_modules/**/*"]
            }
          ],
          "servicePaths": {
            "snapshots": "/snapshots"
          }
        }
      }
    }
  }
}
